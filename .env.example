# Second Me OAuth (保持不变)
SECOND_ME_CLIENT_ID=891fd2b9-0a41-490f-a636-f980d5d1858f
SECOND_ME_CLIENT_SECRET=你的ClientSecret
SECOND_ME_REDIRECT_URI=https://你的项目名.vercel.app/api/auth/callback

# MiniMax LLM（自动吐槽等 AI 功能需要）
# 在 MiniMax 开放平台: 账户管理 → 基本信息 获取 Group ID
# 在 Settings → API Keys 创建并获取 API Key
MINIMAX_API_KEY=你的MiniMaxAPIKey
MINIMAX_GROUP_ID=你的GroupId

# Supabase PostgreSQL 数据库 (部署时必须设置)
# Vercel 部署请使用 Transaction 连接池（端口 6543），适合 serverless
# 在 Supabase 控制台: Project Settings → Database → Connection string → Transaction mode
# 格式: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# 直连（用于 prisma migrate deploy），在 Supabase 控制台: Connection string → Direct connection
# 格式: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
